{
  "name": "node-red-contrib-performance-monitor",
  "version": "2.0.0",
  "description": "Compact, Node-RED 5 native performance monitor: real-time CPU/memory/event-loop metrics, header HUD, node:sqlite history, flow node, and anomaly detection.",
  "main": "performance-monitor.js",
  "scripts": {
    "test": "mocha test/**/*.js --timeout 10000",
    "build": "node build/build.mjs",
    "build:watch": "node build/build.mjs --watch",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "performance-monitor.js",
    "performance-monitor.html",
    "lib/",
    "nodes/",
    "docs/img/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "node-red",
    "sidebar",
    "performance",
    "monitor",
    "cpu",
    "ram",
    "memory",
    "event-loop",
    "dashboard",
    "developer",
    "hud",
    "metrics"
  ],
  "author": "Murat Can Berber",
  "license": "MIT",
  "node-red": {
    "version": ">=4.0.0",
    "plugins": {
      "performance-monitor": "performance-monitor.js"
    },
    "nodes": {
      "perf-monitor": "nodes/perf-monitor-node/perf-monitor-node.js"
    }
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "mocha": "^10.2.0",
    "sinon": "^17.0.1"
  },
  "engines": {
    "node": ">=22.9.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/muratcanberber/node-red-contrib-performance-monitor.git"
  },
  "bugs": {
    "url": "https://github.com/muratcanberber/node-red-contrib-performance-monitor/issues"
  },
  "homepage": "https://github.com/muratcanberber/node-red-contrib-performance-monitor#readme",
  "dependencies": {}
}
